# --- Python 後端忽略清單 ---

# 虛擬環境 (絕對不能上傳！)
venv/
env/
.venv/

# Python 快取檔 (垃圾檔案)
__pycache__/
*.py[cod]
.vs/

# 本地端資料庫 (🌟 重要！確保組員之間不會互相覆蓋資料)
app.db
*.sqlite3

# 環境變數 (金鑰密碼)
.env
.env.local

# --- 前端 Next.js 忽略清單 (🌟 重要！) ---
# 依賴套件 (容量超大，組員需自行 npm install)
node_modules/

# Next.js 編譯產生的檔案
.next/
out/
build/

# 前端環境變數與 Log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*

# --- 編輯器與系統設定 ---
# VS Code 設定
.vscode/

# 作業系統產生的垃圾檔
.DS_Store
Thumbs.db

# 模型檔案(過大，上傳了你會被GitHub爆破)
models/