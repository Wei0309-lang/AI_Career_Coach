# ============================================================
# AI Career Coach - 後端環境變數範本
# 複製此檔案為 .env 並填入實際值，切勿將 .env 上傳至 git
# ============================================================

# --- 資料庫 ---
# 本地開發：使用 SQLite（預設值，不需更改）
# 生產環境：換成 Neon PostgreSQL 連線字串
DATABASE_URL=sqlite:///./app.db

# --- Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- Email 發送（Resend）---
SMTP_PASSWORD=your_resend_api_key_here
SMTP_FROM_EMAIL=noreply@yourdomain.com

# --- 應用程式 URL ---
# 本地開發預設值如下，部署時改成實際網址
BACKEND_URL=http://localhost:8001
FRONTEND_URL=http://localhost:3000

# --- CORS 允許來源 ---
# 多個來源用逗號分隔，不要有空格
# 本地開發：
ALLOWED_ORIGINS=http://localhost:3000
# 生產環境範例：
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# --- Ollama（本地 AI 模型）---
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=my-career-coach

# --- 資料庫重置保護金鑰 ---
# 只有帶上此金鑰才能呼叫 /api/reset-db，請設定一個隨機長字串
ADMIN_SECRET=change_this_to_a_random_secret
