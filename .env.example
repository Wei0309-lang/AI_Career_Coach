# ============================================================
# AI Career Coach - 後端環境變數範本
# 複製此檔案為 .env 並填入實際值，切勿將 .env 上傳至 git
# ============================================================

# --- 資料庫 ---
# 本地開發：使用 SQLite（預設值，不需更改）
# 生產環境：換成 Neon PostgreSQL 連線字串
DATABASE_URL=sqlite:///./app.db

# --- Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- Supabase Auth ---
# 在 Supabase 專案的 Settings > API 頁面可以找到 Project URL
# 後端用它去抓 JWKS 公鑰端點，驗證前端 Supabase 登入後核發的 JWT（非對稱簽章，不需要共享密鑰）
SUPABASE_URL=https://your-project-ref.supabase.co

# --- 使用Gemini AI作為回答模型 ---
USE_GEMINI_CHAT=1

# --- LIVEAVATAR 面試官ID --- #
LIVEAVATAR_AVATAR_ID=your_LIVEAVATAR_AVATAR_ID_here

# --- LIVEAVATAR 面試官人設 --- #
LIVEAVATAR_CONTEXT_ID=your_LIVEAVATAR_CONTEXT_ID_here


# --- LIVEAVATAR 金鑰 --- #
LIVEAVATAR_API_KEY=your_LIVEAVATAR_API_KEY_here
LIVEAVATAR_SANDBOX=1

# --- Azure Speech 金鑰 --- #
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastasia
AZURE_SPEECH_VOICE=zh-TW-HsiaoChenNeural

# --- CORS 允許來源 ---
# 多個來源用逗號分隔，不要有空格
# 本地開發：
ALLOWED_ORIGINS=http://localhost:3000
# 生產環境範例：
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# --- Ollama（本地 AI 模型）---
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=my-career-coach

# --- 資料庫重置保護金鑰 ---
# 只有帶上此金鑰才能呼叫 /api/reset-db，請設定一個隨機長字串
ADMIN_SECRET=change_this_to_a_random_secret
